<?xml version="1.0" encoding="UTF-8"?>
<ProxyEndpoint name="default">
  <PreFlow>
    <Request>
      <!-- Phase 1/2: structural hop-count detection -->
      <Step><Name>JS-LoopDetector</Name></Step>
      <!-- Phase 3: semantic detection via Gemini Flash (hop >= 3, key present, not already blocked) -->
      <Step>
        <Name>JS-BuildGeminiRequest</Name>
        <Condition>loop.do_semantic_check = "true" AND loop.detected = "false"</Condition>
      </Step>
      <Step>
        <Name>AM-BuildGeminiRequest</Name>
        <Condition>loop.do_semantic_check = "true" AND loop.detected = "false"</Condition>
      </Step>
      <Step>
        <Name>SC-GeminiSemanticCheck</Name>
        <Condition>loop.do_semantic_check = "true" AND loop.detected = "false"</Condition>
      </Step>
      <Step>
        <Name>JS-ParseGeminiResponse</Name>
        <Condition>loop.do_semantic_check = "true" AND loop.detected = "false"</Condition>
      </Step>
      <!-- Block on structural OR semantic detection -->
      <Step>
        <Name>RF-LoopDetected</Name>
        <Condition>loop.detected = "true"</Condition>
      </Step>
    </Request>
  </PreFlow>
  <HTTPProxyConnection>
    <BasePath>/ai-agent</BasePath>
  </HTTPProxyConnection>
  <RouteRule name="default">
    <TargetEndpoint>default</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
